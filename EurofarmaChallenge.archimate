  <folder name="Motivation" id="id-68968e6cb4c54318bebfe3858da7a841" type="motivation">
    <element xsi:type="archimate:Stakeholder" name="EUROFARMA" id="id-29fe07f05b4f4964a37bc39c15f5cc28"/>
    <element xsi:type="archimate:Driver" name="Promover a conexão entre nutrizes e bancos de coletas de leite, bem como disseminar a informação sobre a doação de leite" id="id-2e3386e7861f4a73826e3ecfff206c45"/>
    <element xsi:type="archimate:Principle" name="Solução digital por meio de canais digitais visando engajamento das nutrizes" id="id-e6e7e439cffa4a09b982fe151101ea54"/>
    <element xsi:type="archimate:Principle" name="Dashboard com indicadores do projeto" id="id-c0c039402c5b4e60baf966dc4daf5d27"/>
    <element xsi:type="archimate:Principle" name="Funcionalidade que conecte a nutriz aos pontos e/ou banco de coletas" id="id-8e0287a13e3a4e7a9abf3bdf3f3be9bf"/>
    <element xsi:type="archimate:Goal" name="A pagina web contendo informações do projeto e com uma interface amigável a todos" id="id-8b755b6cc95847cc880f2a7bdcb70020"/>
    <element xsi:type="archimate:Goal" name="Chatbot integrado com ferramenta de comunicação para responder dúvidas acerca da doação de leite e informar localização de bancos e postos de coleta" id="id-6489a25a76f9410ba7d4055da73cc874"/>
    <element xsi:type="archimate:Goal" name="Gerar relatórios, dashboards de acompanhamento do engajamento, alcance e conversão" id="id-bdeb3437fecf4d388912444f1adbdd51"/>
    <element xsi:type="archimate:Assessment" name="Ferramentas de desenvolviemento full stack" id="id-a075e2d3eaac4a589c8b38c2495a1bb6"/>
    <element xsi:type="archimate:Assessment" name="Usar um sistema de comunicação instantânea digital e público" id="id-241141e9f8f440d0be0de55448269229"/>
    <element xsi:type="archimate:Assessment" name="Usar solução de BI de mercado" id="id-4604b3ea29ad4618a93737f3b97c4335"/>
    <element xsi:type="archimate:Outcome" name="Chatbot ter os dados mais recentes acerca dos postos e bancos de coleta" id="id-de4b03fa5b764643a25b9fb4c8e04353"/>
    <element xsi:type="archimate:Outcome" name="Chatbot ativo 24/7 " id="id-9a3264d958aa46aaaf5acd07331ee71a"/>
    <element xsi:type="archimate:Outcome" name="Site ativo 24/7" id="id-a46a020cd03c4ecb84a6ccd5b08872f2"/>
    <element xsi:type="archimate:Outcome" name="Todos dados relacionados a engajamento, alcance e conversão devem estar presentes no relatório em até 30 dias depois da implantação do projeto" id="id-c8fb1cb81d0c434681670e026f705ed2"/>
    <element xsi:type="archimate:Outcome" name="Responsivo para todos aparelhos" id="id-8c725555c3d84d2e9b273b857f685b55"/>
    <element xsi:type="archimate:Goal" name="Ter uma página web com as funcionalidades de pesquisa dos postos de coleta" id="id-daab593127804b8fb4b54f310ade8d5f"/>
    <element xsi:type="archimate:Outcome" name="Informações atualizadas 24/7" id="id-21e299a4e8e54bb0999b281190202c78"/>
    <element xsi:type="archimate:Meaning" name="Meaning" id="id-06187a3d27bf4ad1a2a45a9d445a9b7c"/>
  </folder>
